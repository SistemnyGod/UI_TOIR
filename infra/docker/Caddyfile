{
	auto_https off
}

(patrol360_routes) {
	encode zstd gzip

	header {
		?Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; media-src 'self' data: blob:; font-src 'self' data:; connect-src 'self'; form-action 'self'; require-trusted-types-for 'script'"
		?Cross-Origin-Resource-Policy "same-origin"
		?Permissions-Policy "accelerometer=(), bluetooth=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), fullscreen=(self)"
		?Referrer-Policy "strict-origin-when-cross-origin"
		?X-Content-Type-Options "nosniff"
		?X-Frame-Options "DENY"
	}

	handle /api/* {
		reverse_proxy api:8080
	}

	handle /health/* {
		reverse_proxy api:8080
	}

	handle {
		reverse_proxy web:80
	}
}

:80 {
	log {
		output stdout
		format json
	}

	@local_5173_alias {
		header_regexp localHost Host ^(?:localhost|127\.0\.0\.1|\[::1\]):5173$
	}
	redir @local_5173_alias http://192.168.2.194:5173{uri} 308

	@legacy_no_port {
		header_regexp legacyHost Host ^([^:]+)(?::80)?$
		not path /health/*
	}
	redir @legacy_no_port http://{re.legacyHost.1}:5173{uri} 308

	import patrol360_routes
}

:443 {
	log {
		output stdout
		format json
	}

	tls /etc/caddy/certs/patrol360.local.crt /etc/caddy/certs/patrol360.local.key

	header {
		?Cross-Origin-Opener-Policy "same-origin"
		?Strict-Transport-Security "max-age=300"
	}

	import patrol360_routes
}
