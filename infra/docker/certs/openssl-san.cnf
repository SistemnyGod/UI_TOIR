[req]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = distinguished_name
x509_extensions = v3_req

[distinguished_name]
C = RU
ST = Sverdlovsk
L = Yekaterinburg
O = Atom Minerals
OU = Patrol360 Local
CN = 192.168.2.194

[v3_req]
subjectAltName = @alt_names
keyUsage = critical, digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth
basicConstraints = critical, CA:FALSE

[alt_names]
IP.1 = 192.168.2.194
IP.2 = 127.0.0.1
DNS.1 = localhost
DNS.2 = patrol360.local
