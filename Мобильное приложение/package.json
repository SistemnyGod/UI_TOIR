{
  "name": "patrol360-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "prebuild": "expo prebuild",
    "build:android:apk": "powershell -ExecutionPolicy Bypass -File scripts/build-apk.ps1 -Configuration Release",
    "build:android:debug": "powershell -ExecutionPolicy Bypass -File scripts/build-apk.ps1 -Configuration Debug",
    "test:sync": "node --test --experimental-strip-types tests/serializedTaskQueue.test.ts tests/orderedOutboxBatch.test.ts tests/boundedAsync.test.ts tests/outboxContinuationPolicy.test.ts tests/networkPolicy.test.ts tests/diagnosticReportPolicy.test.ts tests/reportDeliveryPresentation.test.ts tests/reportReadinessPresentation.test.ts tests/photoEvidencePolicy.test.ts tests/patrolRulesPhotoPolicy.test.ts tests/fileHash.test.ts tests/fileReferenceIntegrity.test.ts tests/localMediaRetention.test.ts tests/mobileActionLogRetention.test.ts tests/serverFailoverPolicy.test.ts tests/safetyPolicies.test.ts",
    "verify": "npm run test:sync && npm run typecheck && npm run lint",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/vector-icons": "15.1.1",
    "@react-native-community/netinfo": "12.0.1",
    "@tanstack/react-query": "5.100.14",
    "expo": "~56.0.8",
    "expo-background-task": "~56.0.19",
    "expo-camera": "56.0.7",
    "expo-constants": "~56.0.16",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.18",
    "expo-file-system": "56.0.7",
    "expo-font": "~56.0.5",
    "expo-image-manipulator": "~56.0.16",
    "expo-image-picker": "~56.0.15",
    "expo-linking": "~56.0.13",
    "expo-local-authentication": "~56.0.4",
    "expo-notifications": "~56.0.15",
    "expo-router": "~56.2.8",
    "expo-secure-store": "56.0.4",
    "expo-splash-screen": "56.0.10",
    "expo-sqlite": "56.0.4",
    "expo-status-bar": "56.0.4",
    "expo-system-ui": "56.0.5",
    "expo-task-manager": "~56.0.19",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "2.31.2",
    "react-native-nfc-manager": "3.17.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-worklets": "0.8.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/react": "19.2.15",
    "eslint": "9.39.4",
    "eslint-config-expo": "56.0.4",
    "typescript": "6.0.3"
  },
  "overrides": {
    "uuid": "11.1.1"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-nfc-manager",
          "expo-modules-jsi"
        ],
        "listUnknownPackages": false
      }
    }
  }
}
